{
    "案由": "离岗离职后违规从业",
    "法律法规": [
        {
            "名称": "中国共产党纪律处分条例",
            "颁布时间": "2023-12-19",
            "生效时间": "2024-01-01",
            "第几条": "第105条",
            "第几款": "",
            "原文": "离职或者退（离）休后违反有关规定接受原任职务管辖的地区和业务范围内或者与原工作业务直接相关的企业和中介机构等单位的聘用，或者个人从事与原任职务管辖业务或者与原工作业务直接相关的营利活动，情节较轻的，给予警告或者严重警告处分；情节较重的，给予撤销党内职务处分；情节严重的，给予留党察看处分。党员领导干部离职或者退（离）休后违反有关规定担任上市公司、基金管理公司独立董事、独立监事等职务，情节较轻的，给予警告或者严重警告处分；情节较重的，给予撤销党内职务处分；情节严重的，给予留党察看处分。"
        }
    ],
    "规则": [
        {
            "类型": "逻辑运算",
            "计算方式": "非",
            "条件": [
                "《关于退出现职、接近或者达到退休年龄的党政领导干部在企业兼职、任职有关问题的意见》",
                "《关于规范中管干部辞去公职或者退（离）休后担任上市公司、基金管理公司独立董事、独立监事的通知》",
                "《关于规范公务员辞去公职后从业行为的意见》",
                "其他规范公职人员离职或者退（离）休后从业行为的相关制度规定"
            ],
            "结果": "违反有关规定"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "与",
            "条件": [
                "违反有关规定",
                "离职或者退（离）休后",
                "接受原任职务管辖的地区和业务范围内或者与原工作业务直接相关的企业和中介机构等单位的聘用"
            ],
            "结果": "构成离岗离职后违规从业"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "与",
            "条件": [
                "违反有关规定",
                "离职或者退（离）休后",
                "个人从事与原任职务管辖业务或者与原工作业务直接相关的营利活动"
            ],
            "结果": "构成离岗离职后违规从业"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "与",
            "条件": [
                "党员领导干部",
                "违反有关规定",
                "离职或者退（离）休后",
                "担任上市公司、基金管理公司独立董事、独立监事等职务"
            ],
            "结果": "构成离岗离职后违规从业"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "与",
            "条件": [
                "构成离岗离职后违规从业",
                "情节较轻"
            ],
            "结果": "给予警告或者严重警告处分"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "与",
            "条件": [
                "构成离岗离职后违规从业",
                "情节较重"
            ],
            "结果": "给予撤销党内职务处分"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "与",
            "条件": [
                "构成离岗离职后违规从业",
                "情节严重"
            ],
            "结果": "给予留党察看处分"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "或",
            "条件": [
                "行为影响较小，未造成不良后果",
                "初次违规且及时纠正"
            ],
            "结果": "情节较轻"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "或",
            "条件": [
                "行为造成一定不良影响",
                "违规持续时间较长"
            ],
            "结果": "情节较重"
        },
        {
            "类型": "逻辑运算",
            "计算方式": "或",
            "条件": [
                "行为造成恶劣社会影响",
                "违规获利数额巨大",
                "多次违规且拒不纠正"
            ],
            "结果": "情节严重"
        }
    ]
}