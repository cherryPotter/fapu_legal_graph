{
  "案由": "商标权权属、侵权纠纷",
  "法律法规": [
    {
      "名称": "中华人民共和国商标法",
      "生效时间": "2019年11月1日",
      "失效时间": ""
    },
    {
      "名称": "中华人民共和国电子商务法",
      "生效时间": "2019年1月1日",
      "失效时间": ""
    },
    {
      "名称": "中华人民共和国民法典",
      "生效时间": "2021年1月1日",
      "失效时间": ""
    }
  ],
  "规则": [
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "权利基础审查合格",
        "侵权行为审查合格",
        "无有效抗辩事由审查合格",
        "管辖审查合格"
      ],
      "结果": "侵权成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "原告是注册商标权人",
        "原告是商标被许可人且具有诉讼资格"
      ],
      "结果": "权利基础审查合格"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "原告持有有效的商标注册证或续展证明",
        "商标处于有效期内"
      ],
      "结果": "原告是注册商标权人"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "原告持有合法有效的商标使用许可合同",
        "合同明确授予原告独立诉讼权利或原告已获商标权人授权",
        "许可合同已备案或符合法定形式要件"
      ],
      "结果": "原告是商标被许可人且具有诉讼资格"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "构成商标法第五十七条第一项侵权",
        "构成商标法第五十七条第二项侵权",
        "构成商标法第五十七条第三项侵权",
        "构成商标法第五十七条第四项侵权",
        "构成商标法第五十七条第五项侵权",
        "构成商标法第五十七条第六项侵权",
        "构成商标法第五十七条第七项侵权"
      ],
      "结果": "侵权行为审查合格"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "未经商标注册人许可",
        "在同一种商品上使用",
        "使用的商标与注册商标相同",
        "构成商标性使用"
      ],
      "结果": "构成商标法第五十七条第一项侵权"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "未经商标注册人许可",
        "符合商品相同商标近似或商品类似商标相同近似情形",
        "容易导致混淆",
        "构成商标性使用"
      ],
      "结果": "构成商标法第五十七条第二项侵权"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "在同一种商品上使用近似商标",
        "在类似商品上使用相同商标",
        "在类似商品上使用近似商标"
      ],
      "结果": "符合商品相同商标近似或商品类似商标相同近似情形"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "销售了商品",
        "该商品是侵犯注册商标专用权的商品",
        "不能证明该商品是自己合法取得并说明提供者"
      ],
      "结果": "构成商标法第五十七条第三项侵权"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "伪造他人注册商标标识",
        "擅自制造他人注册商标标识",
        "销售伪造的注册商标标识",
        "销售擅自制造的注册商标标识"
      ],
      "结果": "构成商标法第五十七条第四项侵权"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "未经商标注册人同意",
        "更换其注册商标",
        "将该更换商标的商品又投入市场"
      ],
      "结果": "构成商标法第五十七条第五项侵权"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "主观上为故意",
        "客观上为侵犯他人商标专用权行为提供了便利条件",
        "帮助他人实施了侵犯商标专用权行为"
      ],
      "结果": "构成商标法第五十七条第六项侵权"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "实施了其他行为",
        "该行为给他人的注册商标专用权造成了损害",
        "符合相关法律或司法解释规定的其他情形"
      ],
      "结果": "构成商标法第五十七条第七项侵权"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "被告在商业活动中使用了标识",
        "该使用行为用于识别商品或服务来源"
      ],
      "结果": "构成商标性使用"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "将标识用于商品、商品包装或容器",
        "将标识用于商品交易文书",
        "将标识用于广告宣传、展览",
        "将标识用于网站、社交媒体等网络宣传",
        "将标识用于门店招牌、装潢"
      ],
      "结果": "被告在商业活动中使用了标识"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "无抗辩事由",
        "抗辩事由审查不成立"
      ],
      "结果": "无有效抗辩事由审查合格"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "权利用尽抗辩成立",
        "先用权抗辩成立",
        "描述性使用抗辩成立",
        "指示性使用抗辩成立",
        "合法来源抗辩成立",
        "诉讼时效抗辩成立"
      ],
      "结果": "抗辩事由审查成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "非",
      "条件": [
        "抗辩事由审查成立"
      ],
      "结果": "抗辩事由审查不成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "商品来源于商标权人或其被许可人",
        "商品状态未被改变",
        "商品已投入市场"
      ],
      "结果": "权利用尽抗辩成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "商标使用行为发生在注册商标申请日之前并持续至申请日",
        "被进行真实、公开、合法的商标型商业使用",
        "商品或服务相同或近似",
        "在先使用商标具有一定影响"
      ],
      "结果": "先用权抗辩成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "使用方是描述商品或服务特征所必需的",
        "使用出于善意",
        "使用不会导致相关公众混淆"
      ],
      "结果": "描述性使用抗辩成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "使用商标是为指明商品、服务的用途、兼容性、适配对象等所合理必需的",
        "使用在合理、必要的限度，且方式符合诚实信用和商业管理",
        "使用未对商标的识别功能或声誉造成不合理损害"
      ],
      "结果": "指示性使用抗辩成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "所售商品来源明确且合法",
        "被告主观不知道商品侵权",
      ],
      "结果": "合法来源抗辩成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "一般时效届满",
        "自权利受到损害之日起已超过二十年",
      ],
      "结果": "诉讼时效抗辩成立"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "且",
      "条件": [
        "原告知道或应当知道权利被侵害",
        "自知道之日起已超过三年",
        "无中止、中断法定事由"
      ],
      "结果": "一般时效届满"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "约定管辖审查合格",
        "法定管辖审查合格"
      ],
      "结果": "管辖审查合格"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "商标许可或转让合同中有管辖约定",
        "约定管辖不违反级别管辖和专属管辖",
        "被诉侵权行为实施地或被告住所地在约定法院辖区",
        "审理法院为约定法院"
      ],
      "结果": "约定管辖审查合格"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "无有效约定管辖",
        "侵权行为地或被告住所地法院受理"
      ],
      "结果": "法定管辖审查合格"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "侵权商品储藏地",
        "侵权商品查封扣押地",
        "被告住所地"
      ],
      "结果": "侵权行为地或被告住所地法院受理"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "侵权成立",
        "原告提出停止侵害请求"
      ],
      "结果": "应当判决停止侵害"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "侵权成立",
        "原告提出损害赔偿请求",
        "赔偿计算审查合格"
      ],
      "结果": "应当判决赔偿损失"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "或",
      "条件": [
        "原告实际损失可确定",
        "被告侵权获利可确定",
        "商标许可使用费的合理倍数可确定",
        "适用法定赔偿"
      ],
      "结果": "赔偿计算审查合格"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "原告提供充分证据证明实际损失",
        "损失与侵权行为有因果关系"
      ],
      "结果": "原告实际损失可确定"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "被告账簿、资料完整或法院责令提供",
        "获利与侵权行为有直接关联"
      ],
      "结果": "被告侵权获利可确定"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "存在真实、合法的商标许可合同",
        "许可费合理且有可比性",
        "根据情节在一至五倍范围内确定"
      ],
      "结果": "商标许可使用费的合理倍数可确定"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "前三种方式均难以确定",
        "法院根据侵权情节酌情判决",
        "赔偿数额在五百万元以下"
      ],
      "结果": "适用法定赔偿"
    },
    {
      "类型": "逻辑运算",
      "计算方式": "与",
      "条件": [
        "侵权成立",
        "原告提出消除影响请求",
        "侵权行为造成较大社会影响"
      ],
      "结果": "可以判决消除影响"
    }
  ]
}