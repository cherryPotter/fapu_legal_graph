{
    "案由": "通信秘密违宪审查",
    "法律法规": [
        {
            "名称": "宪法",
            "颁布时间": "1982-12-04",
            "生效时间": "1982-12-04",
            "第几条": "第四十条",
            "第几款": "",
            "原文": "中华人民共和国公民的通信自由和通信秘密受法律的保护。除因国家安全或者追查刑事犯罪的需要，由公安机关或者检察机关依照法律规定的程序对通信进行检查外，任何组织或者个人不得以任何理由侵犯公民的通信自由和通信秘密。"
        }
    ],
